module WriterTest;


import Minilib.Monad.Writer;
import Minilib.Monad.Trans;
import Minilib.Monad.Error;
import Minilib.Monad.IO;
import Minilib.Trait.Monoid;
import Minilib.Trait.Semigroup;
import Minilib.Text.StringEx;
import Minilib.Testing.UnitTest;

test_writer_functor: TestCase;
test_writer_functor = (
    make_test("test_writer_functor") $ |_|
    let w = writer(["a"], 2);
    let w = w.map(add(1));
    let w = w.map(to_string);
    assert_equal("eq", (["a"], "3"), w.run_writer)
);

test_writer_monad: TestCase;
test_writer_monad = (
    make_test("test_writer_monad") $ |_|
    let w = do {
        let x = *pure(2);
        tell(["a"]);;
        tell(["b","c"]);;
        pure(x + 1)
    };
    assert_equal("eq", (["a", "b", "c"], 3), w.run_writer)
);

test_tell_listen: TestCase;
test_tell_listen = (
    make_test("test_tell_listen") $ |_|
    let w: WriterT String IOFail I64 = do {
        let i64val = *pure(2);
        tell("log1");;
        pure(i64val + 1)
    };
    let w2: WriterT String IOFail String = do {
        tell("log0");;
        let (log, i64val) = *w.listen;
        tell("log2");;
        pure("log="+log+" i64val="+i64val.to_string)
    };
    assert_equal("eq", ("log0log1log2", "log=log1 i64val=3"), *w2.run_writer_t)
);

test_pass: TestCase;
test_pass = (
    make_test("test_pass") $ |_|
    let w: WriterT String IOFail I64 = do {
        let i64val = *pure(2);
        tell("log1");;
        pure(i64val + 1)
    };

    let w2: WriterT String IOFail String = do {
        tell("log0");;
        let f = |e| "<" + e + ">";
        let i64val = *w.map(|i64val| (f, i64val)).pass;
        tell("log2");;
        pure("i64val=" + i64val.to_string)
    };
    assert_equal("eq", ("log0<log1>log2", "i64val=3"), *w2.run_writer_t)
);

test_map_writer_t: TestCase;
test_map_writer_t = (
    make_test("test_map_writer_t") $ |_|
    let w: WriterT String IO I64 = do {
        let i64val = *pure(2);
        tell("log1");;
        pure(i64val + 1)
    };
    let f: IO (String, I64) -> IOFail (Array String, F64) = |io| (
        let (e, a) = *io.lift;
        pure $ ([e], a.f64)
    );
    let w2: WriterT (Array String) IOFail String = do {
        tell(["log0"]);;
        let f64val = *w.map_writer_t(f);
        tell(["log2"]);;
        pure("f64val=" + f64val.to_string)
    };
    assert_equal("eq", (["log0","log1","log2"], "f64val=3.000000"), *w2.run_writer_t)
);

test_writer_trans: TestCase;
test_writer_trans = (
    make_test("test_writer_trans") $ |_|
    let iof: IOFail F64 = pure(123.45);
    let w: WriterT String IOFail F64 = iof.lift_t;
    let expected = 123.45;
    let (e, actual) = *w.run_writer_t;
    assert_equal("e", "", e);;
    assert_equal("eq", expected, actual)
);

test_writer_iofail_error: TestCase;
test_writer_iofail_error = (
    make_test("test_writer_iofail_error") $ |_|
    let iof: I64 -> IOFail F64 = |i64val| (
        if i64val >= 100 { throw $ "err1" };
        pure $ i64val.f64 * 2.0
    );
    let w: I64 -> WriterT String IOFail F64 = |i64val| (
        tell("start ");;
        if i64val < 0 { error $ "err2" };
        tell(i64val.to_string);;
        let f64val = *iof(i64val).lift_t;
        pure $ f64val
    );
    assert_equal("ok", ok $ ("start 12", 24.0), *w(12).run_writer_t.to_result.lift);;
    assert_equal("err1", err("err1"), *w(100).run_writer_t.to_result.lift);;
    assert_equal("err2", err("err2"), *w(-1).run_writer_t.to_result.lift);;
    let handler: ErrMsg -> WriterT String IOFail F64 = |errmsg| (
        tell("caught " + errmsg);;
        if errmsg == "err1" { pure $ 999.0 };
        error $ "rethrow: " + errmsg
    );
    let w2 = |i64val| (
        let f64val = *w(i64val).catch(handler);
        tell(" end");;
        pure $ f64val
    );
    assert_equal("catch ok", ok $ ("start 12 end", 24.0), *w2(12).run_writer_t.to_result.lift);;
    assert_equal("catch err1", ok $ ("caught err1 end", 999.0), *w2(100).run_writer_t.to_result.lift);;
    assert_equal("catch err2", err("rethrow: err2"), *w2(-1).run_writer_t.to_result.lift);;
    pure()
);

test_lift_io: TestCase;
test_lift_io = (
    make_test("test_lift_io") $ |_|
    let inner_io: IO I64 = do {
        //println("inner_io");;
        pure $ 42
    };
    let inner_iofail: IOFail I64 = do {
        //println("inner_iofail").lift;;
        pure $ 57
    };
    let w: WriterT (Array I64) IOFail () = do {
        tell([*inner_io.lift_io]);;
        tell([*inner_iofail.lift_iofail]);;
        pure()
    };
    let expected = ok $ ([42, 57], ());
    let actual = *w.run_writer_t.to_result.lift;
    assert_equal("eq", expected, actual)
);

main: IO ();
main = (
    [
        test_writer_functor,
        test_writer_monad,
        test_tell_listen,
        test_pass,
        test_map_writer_t,
        test_writer_trans,
        test_writer_iofail_error,
        test_lift_io,
    ]
    .run_test_driver
);

